{
  "name": "@ilytat/ai-manager",
  "version": "0.1.0",
  "description": "Multi-provider AI text generation with waterfall fallback. Supports Anthropic, Gemini, OpenAI, Ollama, Mistral, Groq, and Cohere. Zero runtime dependencies.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "llm",
    "anthropic",
    "claude",
    "gemini",
    "openai",
    "ollama",
    "mistral",
    "groq",
    "waterfall",
    "multi-provider"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
