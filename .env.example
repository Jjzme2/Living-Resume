# ================================================================
#  Environment Variables — copy to .env.local and fill in values
# ================================================================

# ── Admin Auth ───────────────────────────────────────────────────
NUXT_ADMIN_PASSWORD=
NUXT_JWT_SECRET=

# ── Firebase Client SDK (public, safe to expose) ─────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin SDK (server-side, keep secret) ────────────────
# Generate from Firebase Console → Project Settings → Service accounts → Generate new private key
# FIREBASE_PROJECT_ID can be omitted — auto-detected from VITE_FIREBASE_PROJECT_ID
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Email (Resend) ───────────────────────────────────────────────
# https://resend.com/dashboard
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# ── AI Resume Parser (Anthropic) ─────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Blog Publishing (GitHub) ─────────────────────────────────────
# Personal access token with repo write scope
GITHUB_TOKEN=
GITHUB_REPO=username/repo-name

# ── Cron Job Protection ──────────────────────────────────────────
# Must match the secret in vercel.json cron path
CRON_SECRET=
